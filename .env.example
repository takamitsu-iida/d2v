# --- LLMプロバイダー選択 ---
# "openai" / "azure" / "anthropic" / "ollama" のいずれかを指定
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o

# Azure OpenAI Service（api-key ヘッダー方式の REST エンドポイント）
AZURE_OPENAI_API_KEY=your_key_here
# モデルまで含んだ完全なエンドポイント URL
# 例: https://api.ai-service.global.fujitsu.com/ai-foundation/chat-ai/gpt/gpt-5.1
AZURE_OPENAI_ENDPOINT=https://your-endpoint/.../gpt/your-model

# Anthropic
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama（ローカルLLM）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:70b

# Cisco CML
CML_URL=https://your-cml-server
CML_USERNAME=admin
CML_PASSWORD=your_password
CML_VERIFY_SSL=false

# エージェント設定
MAX_RETRIES=5

# 分割詳細図の境界スタブ集約しきい値
# 1 つの外部ゾーンからの境界スタブがこの数を超えたら 1 ノードに集約する
# （詳細図が横に伸びすぎるのを防ぐ。小さくするほど積極的に集約）
BOUNDARY_AGG_THRESHOLD=3

# 図の目標縦横比（幅/高さ）。横長すぎる図は rankdir=LR で縦積みにしてこの比に近づける。
# 3:4（縦3・楡4）なら 1.333。値を小さくするほど縦長を許容。0 以下で無効化。
DIAGRAM_ASPECT_RATIO=1.333

# 縦横比調整の許容倍率。幅/高さが目標比のこの倍数以内なら切り替えない。
# 大きくするほど横長を許容し、rankdir の組み替えを抑える。
DIAGRAM_ASPECT_TOLERANCE=2.0

# Web GUI: 貼り付け YAML の最大バイト数（過大入力によるリソース枯渇を防ぐ）
WEBUI_MAX_YAML_BYTES=1000000

# Web GUI: 同時に実行できるジョブ数の上限（待機中＋実行中の合計）
WEBUI_MAX_ACTIVE_JOBS=4
